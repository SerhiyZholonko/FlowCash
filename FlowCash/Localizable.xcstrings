    "Усі транзакції та рахунки буде видалено, зокрема з iCloud. Категорії скинуться до дефолтних." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Transaktionen und Konten werden gelöscht, auch aus iCloud. Die Kategorien werden auf die Standardwerte zurückgesetzt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All transactions and accounts will be deleted, including from iCloud. Categories will reset to defaults."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se eliminarán todas las transacciones y cuentas, incluidas las de iCloud. Las categorías se restablecerán a los valores predeterminados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toutes les transactions et tous les comptes seront supprimés, y compris d'iCloud. Les catégories seront réinitialisées par défaut."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sve transakcije i računi bit će izbrisani, uključujući iz iClouda. Kategorije će se vratiti na zadane."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutte le transazioni e i conti verranno eliminati, anche da iCloud. Le categorie verranno ripristinate ai valori predefiniti."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Semua transaksi dan akaun akan dipadam, termasuk dari iCloud. Kategori akan ditetapkan semula kepada lalai."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle transaksjoner og kontoer slettes, også fra iCloud. Kategoriene tilbakestilles til standard."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wszystkie transakcje i konta zostaną usunięte, również z iCloud. Kategorie zostaną przywrócone do domyślnych."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todas as transações e contas serão excluídas, inclusive do iCloud. As categorias voltarão ao padrão."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tüm işlemler ve hesaplar, iCloud dahil silinecek. Kategoriler varsayılana sıfırlanacak."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有交易和账户都将被删除，包括 iCloud 中的数据。类别将重置为默认值。"
          }
        }
      }
    },
