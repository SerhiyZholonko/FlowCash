    "Рахуй витрати за 5 секунд.\nОдин погляд — повна картина." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erfasse Ausgaben in 5 Sekunden.\nEin Blick — das ganze Bild."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Track expenses in 5 seconds.\nOne glance — the full picture."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra gastos en 5 segundos.\nUn vistazo — la imagen completa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrez vos dépenses en 5 secondes.\nUn coup d'œil — la vue d'ensemble."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zabilježite troškove u 5 sekundi.\nJedan pogled — cijela slika."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra le spese in 5 secondi.\nUno sguardo — il quadro completo."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rekod perbelanjaan dalam 5 saat.\nSatu pandangan — gambaran penuh."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registrer utgifter på 5 sekunder.\nEtt blikk — hele bildet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zapisuj wydatki w 5 sekund.\nJedno spojrzenie — pełny obraz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registre despesas em 5 segundos.\nUm olhar — o quadro completo."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Giderleri 5 saniyede kaydet.\nTek bakışta tam görünüm."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "5 秒记录支出。\n一眼看清全貌。"
          }
        }
      }
    },
